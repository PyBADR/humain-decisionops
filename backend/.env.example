# ===========================================
# Humain DecisionOps Backend Configuration
# ===========================================

# Database (Required)
# For local Docker: postgresql://humain:humain_secret@localhost:5432/humain_decisionops
# For Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/humain_decisionops?sslmode=require
DATABASE_URL=postgresql://humain:humain_secret@localhost:5432/humain_decisionops

# MongoDB (Optional - for raw document storage)
MONGO_URL=mongodb://humain:humain_secret@localhost:27017/

# ===========================================
# Operating Mode
# ===========================================

# Set to true to run database seed on startup (for fresh deployments)
SEED_ON_STARTUP=false

# Set to true to force heuristic mode (no LLM calls)
# Useful for free-tier deployments without LLM access
HEURISTIC_MODE=false

# ===========================================
# LLM Providers (Optional)
# ===========================================

# OpenAI - if set, will use OpenAI for LLM calls
OPENAI_API_KEY=

# Ollama - local LLM server (used if OPENAI_API_KEY not set)
OLLAMA_BASE_URL=http://localhost:11434

# ===========================================
# LangSmith Tracing (Optional)
# ===========================================

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=humain-decisionops

# ===========================================
# API Authentication (Optional)
# ===========================================

API_KEY=
AUTH_ENABLED=false

# ===========================================
# CORS Configuration
# ===========================================

# Comma-separated list of allowed origins, or "*" for all
# Example: https://humain-decisionops.vercel.app,http://localhost:3000
CORS_ALLOW_ORIGINS=*

# ===========================================
# Logging
# ===========================================

LOG_LEVEL=INFO

# ===========================================
# File Storage (Docker paths)
# ===========================================

UPLOAD_DIR=/app/uploads
POLICY_DIR=/app/policies
