# Database
POSTGRES_USER=humain
POSTGRES_PASSWORD=humain_secret
POSTGRES_DB=humain_decisionops

# MongoDB (optional)
MONGO_USER=humain
MONGO_PASSWORD=humain_secret

# pgAdmin
PGADMIN_EMAIL=admin@humain.local
PGADMIN_PASSWORD=admin123

# LLM Providers (optional - uses Ollama by default)
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# LangSmith Tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=humain-decisionops

# API Authentication (optional)
API_KEY=
AUTH_ENABLED=false

# Logging
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
